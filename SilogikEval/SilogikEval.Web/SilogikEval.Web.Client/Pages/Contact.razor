@page "/contact"
@rendermode InteractiveWebAssembly
@using SilogikEval.Web.Client.Components
@using SilogikEval.Web.Client.Models
@using SilogikEval.Web.Client.Services
@inject IApiContactService ContactService
@inject IApiTranslationService TranslationService
@inject ILanguageStateService LanguageState
@implements IDisposable

<PageTitle>@T("label.contacts", "Contactos")</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>@T("label.contacts", "Contactos")</h3>
    <button class="btn btn-primary" @onclick="OpenModal">
        + @T("label.add_contact", "Agregar Contacto")
    </button>
</div>

<ContactList PagedResult="_pagedResult" Translations="_translations"
             OnViewContact="ViewContactAsync"
             OnEditContact="EditContactAsync"
             OnPageChanged="OnPageChangedAsync"
             OnSearchChanged="OnSearchChangedAsync" />

<ContactDetailModal IsVisible="_showDetail"
                    Contact="_selectedContact"
                    Translations="_translations"
                    OnClose="CloseDetail" />

<ContactEditModal IsVisible="_showEdit"
                  Contact="_editContact"
                  Translations="_translations"
                  OnClose="CloseEdit"
                  OnContactUpdated="OnContactUpdatedAsync"
                  OnSubmit="ContactService.UpdateAsync" />

<ContactFormModal IsVisible="_showModal"
                  Translations="_translations"
                  OnClose="CloseModal"
                  OnContactCreated="LoadContactsAsync"
                  OnSubmit="ContactService.CreateAsync" />

@code {
    private PagedResultModel<ContactModel>? _pagedResult;
    private IDictionary<string, string> _translations = new Dictionary<string, string>();
    private bool _showModal;
    private bool _showDetail;
    private bool _showEdit;
    private ContactModel? _selectedContact;
    private ContactModel? _editContact;

    private int _currentPage = 1;
    private const int PageSize = 10;
    private string? _currentSearch;

    protected override async Task OnInitializedAsync()
    {
        LanguageState.OnLanguageChanged += OnLanguageChanged;
        await LoadTranslationsAsync();
        await LoadContactsAsync();
    }

    private async Task LoadTranslationsAsync()
    {
        _translations = await TranslationService.GetTranslationsAsync(LanguageState.CurrentLanguage);
    }

    private async Task LoadContactsAsync()
    {
        _pagedResult = await ContactService.GetAllAsync(_currentPage, PageSize, _currentSearch);
        StateHasChanged();
    }

    private async Task OnPageChangedAsync(int page)
    {
        _currentPage = page;
        await LoadContactsAsync();
    }

    private async Task OnSearchChangedAsync(string? search)
    {
        _currentSearch = search;
        _currentPage = 1;
        await LoadContactsAsync();
    }

    private async void OnLanguageChanged()
    {
        await LoadTranslationsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void OpenModal()
    {
        _showModal = true;
        StateHasChanged();
    }

    private void CloseModal()
    {
        _showModal = false;
        StateHasChanged();
    }

    private async Task ViewContactAsync(Guid id)
    {
        _selectedContact = null;
        _showDetail = true;
        StateHasChanged();

        _selectedContact = await ContactService.GetByIdAsync(id);
        StateHasChanged();
    }

    private void CloseDetail()
    {
        _showDetail = false;
        _selectedContact = null;
        StateHasChanged();
    }

    private async Task EditContactAsync(Guid id)
    {
        _editContact = null;
        _showEdit = true;
        StateHasChanged();

        _editContact = await ContactService.GetByIdAsync(id);
        StateHasChanged();
    }

    private void CloseEdit()
    {
        _showEdit = false;
        _editContact = null;
        StateHasChanged();
    }

    private async Task OnContactUpdatedAsync()
    {
        await LoadContactsAsync();
    }

    private string T(string key, string fallback)
    {
        return _translations.TryGetValue(key, out var value) ? value : fallback;
    }

    public void Dispose()
    {
        LanguageState.OnLanguageChanged -= OnLanguageChanged;
    }
}
