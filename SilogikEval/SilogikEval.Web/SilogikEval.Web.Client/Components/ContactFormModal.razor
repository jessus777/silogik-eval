@using SilogikEval.Web.Client.Models
@using System.Text.RegularExpressions
@using Microsoft.AspNetCore.Components.Forms
@inject SilogikEval.Web.Client.Services.ISweetAlertService Swal

@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@T("label.add_contact", "Agregar Contacto")</h5>
                    <button type="button" class="btn-close" @onclick="Close" disabled="@_isSubmitting"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">@T("label.email", "Email") *</label>
                            <input type="email" class="form-control @ValidationCss(nameof(_model.Email))"
                                   @bind="_model.Email" />
                            @if (HasFieldError(nameof(_model.Email)))
                            {
                                <div class="invalid-feedback d-block">@GetFieldError(nameof(_model.Email))</div>
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@T("label.firstname", "Nombre") *</label>
                            <input type="text" class="form-control @ValidationCss(nameof(_model.FirstName))"
                                   @bind="_model.FirstName" />
                            @if (HasFieldError(nameof(_model.FirstName)))
                            {
                                <div class="invalid-feedback d-block">@GetFieldError(nameof(_model.FirstName))</div>
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@T("label.secondname", "Segundo nombre")</label>
                            <input type="text" class="form-control @ValidationCss(nameof(_model.SecondName))"
                                   @bind="_model.SecondName" />
                            @if (HasFieldError(nameof(_model.SecondName)))
                            {
                                <div class="invalid-feedback d-block">@GetFieldError(nameof(_model.SecondName))</div>
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@T("label.lastname", "Apellido paterno") *</label>
                            <input type="text" class="form-control @ValidationCss(nameof(_model.LastName))"
                                   @bind="_model.LastName" />
                            @if (HasFieldError(nameof(_model.LastName)))
                            {
                                <div class="invalid-feedback d-block">@GetFieldError(nameof(_model.LastName))</div>
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@T("label.secondlastname", "Apellido materno")</label>
                            <input type="text" class="form-control @ValidationCss(nameof(_model.SecondLastName))"
                                   @bind="_model.SecondLastName" />
                            @if (HasFieldError(nameof(_model.SecondLastName)))
                            {
                                <div class="invalid-feedback d-block">@GetFieldError(nameof(_model.SecondLastName))</div>
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@T("label.attachment", "Adjunto")</label>
                            <InputFile class="form-control"
                                       OnChange="OnFileSelected" accept=".jpg,.jpeg,.png,.pdf" />
                            @if (HasFieldError("Attachment"))
                            {
                                <div class="invalid-feedback d-block">@GetFieldError("Attachment")</div>
                            }
                        </div>
                        <div class="col-12">
                            <label class="form-label">@T("label.comments", "Comentarios") *</label>
                            <textarea class="form-control @ValidationCss(nameof(_model.Comments))"
                                      rows="3" @bind="_model.Comments"></textarea>
                            @if (HasFieldError(nameof(_model.Comments)))
                            {
                                <div class="invalid-feedback d-block">@GetFieldError(nameof(_model.Comments))</div>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="Close"
                            disabled="@_isSubmitting">
                        @T("button.cancel", "Cancelar")
                    </button>
                    <button type="button" class="btn btn-primary" @onclick="RequestSubmit"
                            disabled="@_isSubmitting">
                        @if (_isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        @T("button.submit", "Enviar")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public IDictionary<string, string> Translations { get; set; } = new Dictionary<string, string>();
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnContactCreated { get; set; }
    [Parameter] public Func<CreateContactModel, Task<ApiResponseModel<Guid>>>? OnSubmit { get; set; }

    private CreateContactModel _model = new();
    private Dictionary<string, string> _fieldErrors = new();
    private bool _isSubmitting;
    private bool _hasAttemptedSubmit;

    private static readonly Regex AlphabeticRegex = new(@"^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ\s]+$", RegexOptions.Compiled);
    private static readonly Regex EmailRegex = new(@"^[^@\s]+@[^@\s]+\.[^@\s]+$", RegexOptions.Compiled);
    private static readonly string[] AllowedExtensions = [".jpg", ".jpeg", ".png", ".pdf"];

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _model.Attachment = e.File;

        if (_hasAttemptedSubmit)
            ValidateField("Attachment");
    }

    private bool ValidateForm()
    {
        _fieldErrors.Clear();
        _hasAttemptedSubmit = true;

        if (string.IsNullOrWhiteSpace(_model.Email))
            _fieldErrors["Email"] = T("validation.email.required", "El correo electrónico es obligatorio.");
        else if (!EmailRegex.IsMatch(_model.Email))
            _fieldErrors["Email"] = T("validation.email.invalid_format", "El formato del correo no es válido.");

        if (string.IsNullOrWhiteSpace(_model.FirstName))
            _fieldErrors["FirstName"] = T("validation.firstname.required", "El nombre es obligatorio.");
        else if (!AlphabeticRegex.IsMatch(_model.FirstName))
            _fieldErrors["FirstName"] = T("validation.firstname.alphabetic_only", "El nombre solo permite caracteres alfabéticos.");

        if (string.IsNullOrWhiteSpace(_model.LastName))
            _fieldErrors["LastName"] = T("validation.lastname.required", "El apellido paterno es obligatorio.");
        else if (!AlphabeticRegex.IsMatch(_model.LastName))
            _fieldErrors["LastName"] = T("validation.lastname.alphabetic_only", "El apellido paterno solo permite caracteres alfabéticos.");

        if (!string.IsNullOrWhiteSpace(_model.SecondName) && !AlphabeticRegex.IsMatch(_model.SecondName))
            _fieldErrors["SecondName"] = T("validation.secondname.alphabetic_only", "El segundo nombre solo permite caracteres alfabéticos.");

        if (!string.IsNullOrWhiteSpace(_model.SecondLastName) && !AlphabeticRegex.IsMatch(_model.SecondLastName))
            _fieldErrors["SecondLastName"] = T("validation.secondlastname.alphabetic_only", "El apellido materno solo permite caracteres alfabéticos.");

        if (string.IsNullOrWhiteSpace(_model.Comments))
            _fieldErrors["Comments"] = T("validation.comments.required", "Los comentarios son obligatorios.");
        else if (!AlphabeticRegex.IsMatch(_model.Comments))
            _fieldErrors["Comments"] = T("validation.comments.alphabetic_only", "Los comentarios solo permiten caracteres alfabéticos.");

        ValidateField("Attachment");

        return _fieldErrors.Count == 0;
    }

    private void ValidateField(string fieldName)
    {
        _fieldErrors.Remove(fieldName);

        if (fieldName == "Attachment" && _model.Attachment is not null)
        {
            var ext = Path.GetExtension(_model.Attachment.Name).ToLower();
            if (!AllowedExtensions.Contains(ext))
                _fieldErrors["Attachment"] = T("error.file.extension_not_allowed", "Extensión de archivo no permitida.");
            else if (_model.Attachment.Size > 5 * 1024 * 1024)
                _fieldErrors["Attachment"] = T("error.file.size_exceeded", "El archivo excede el tamaño permitido.");
        }
    }

    private async Task RequestSubmit()
    {
        if (!ValidateForm())
            return;

        var confirmed = await Swal.ConfirmAsync(
            T("message.confirm_send", "¿Está seguro de enviar el formulario?"),
            "",
            T("button.confirm", "Confirmar"),
            T("button.cancel", "Cancelar"));

        if (!confirmed)
            return;

        _isSubmitting = true;
        StateHasChanged();

        await Swal.ShowLoadingAsync(T("message.sending", "Enviando..."));

        try
        {
            if (OnSubmit is not null)
            {
                var result = await OnSubmit(_model);

                await Swal.CloseAsync();

                if (result.Success)
                {
                    _model = new CreateContactModel();
                    _fieldErrors.Clear();
                    _hasAttemptedSubmit = false;
                    await OnContactCreated.InvokeAsync();

                    await Swal.SuccessAsync(
                        T("message.success", "El formulario se envió correctamente."),
                        result.Message);
                }
                else
                {
                    var errorText = result.Errors?.Any() == true
                        ? string.Join("\n", result.Errors)
                        : result.Message;

                    await Swal.ErrorAsync(
                        T("message.error", "Ocurrió un error"),
                        errorText);
                }
            }
        }
        catch
        {
            await Swal.CloseAsync();
            await Swal.ErrorAsync(
                T("message.error", "Ocurrió un error"),
                T("error.unexpected", "Ocurrió un error inesperado."));
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task Close()
    {
        _model = new CreateContactModel();
        _fieldErrors.Clear();
        _hasAttemptedSubmit = false;
        await OnClose.InvokeAsync();
    }

    private bool HasFieldError(string field) => _hasAttemptedSubmit && _fieldErrors.ContainsKey(field);

    private string GetFieldError(string field) => _fieldErrors.TryGetValue(field, out var msg) ? msg : "";

    private string ValidationCss(string field)
    {
        if (!_hasAttemptedSubmit) return "";
        return _fieldErrors.ContainsKey(field) ? "is-invalid" : "is-valid";
    }

    private string T(string key, string fallback)
    {
        return Translations.TryGetValue(key, out var value) ? value : fallback;
    }
}
