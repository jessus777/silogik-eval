@using SilogikEval.Web.Client.Models

<div class="card shadow">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">@T("label.contacts", "Contactos")</h5>
    </div>
    <div class="card-body">

        <div class="row mb-3">
            <div class="col-md-4">
                <div class="input-group">
                    <input type="text" class="form-control" placeholder="@T("label.search", "Buscar por email o nombre...")"
                           @bind="_searchText" @bind:event="oninput" @onkeydown="HandleSearchKeyDown" />
                    <button class="btn btn-outline-primary" type="button" @onclick="ExecuteSearch">
                        <span class="bi bi-search"></span>
                    </button>
                    @if (!string.IsNullOrWhiteSpace(_searchText))
                    {
                        <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                            <span class="bi bi-x-lg"></span>
                        </button>
                    }
                </div>
            </div>
        </div>

        @if (PagedResult is null)
        {
            <div class="text-center py-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else if (!PagedResult.Items.Any())
        {
            <p class="text-muted text-center mb-0">@T("label.no_records", "No hay registros.")</p>
        }
        else
        {
            <div class="table-responsive" style="overflow:visible;">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>@T("label.email", "Email")</th>
                            <th>@T("label.firstname", "Nombre")</th>
                            <th>@T("label.secondname", "Segundo nombre")</th>
                            <th>@T("label.lastname", "Apellido paterno")</th>
                            <th>@T("label.secondlastname", "Apellido materno")</th>
                            <th>@T("label.comments", "Comentarios")</th>
                            <th>@T("label.attachment", "Adjunto")</th>
                            <th class="text-center">@T("label.actions", "Acciones")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var contact in PagedResult.Items)
                        {
                            <tr>
                                <td>@contact.Email</td>
                                <td>@contact.FirstName</td>
                                <td>@(contact.SecondName ?? "—")</td>
                                <td>@contact.LastName</td>
                                <td>@(contact.SecondLastName ?? "—")</td>
                                <td>@contact.Comments</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(contact.FilePath))
                                    {
                                        <span class="badge bg-success">✓</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="position-relative d-inline-block">
                                        <button class="btn btn-sm btn-outline-secondary"
                                                @onclick="() => ToggleMenu(contact.Id)">
                                            <span class="bi bi-list"></span>
                                        </button>
                                        @if (_openMenuId == contact.Id)
                                        {
                                            <div class="dropdown-menu show shadow-sm" style="position:absolute; right:0; top:100%; z-index:1050; min-width:160px;">
                                                <button class="dropdown-item d-flex align-items-center gap-2" type="button"
                                                        @onclick="() => OnView(contact.Id)">
                                                    <span class="bi bi-eye"></span> @T("button.view", "Ver")
                                                </button>
                                                <button class="dropdown-item d-flex align-items-center gap-2" type="button"
                                                        @onclick="() => OnEdit(contact.Id)">
                                                    <span class="bi bi-pencil"></span> @T("button.edit", "Editar")
                                                </button>
                                                <div class="dropdown-divider"></div>
                                                <button class="dropdown-item d-flex align-items-center gap-2 text-danger" type="button" disabled>
                                                    <span class="bi bi-trash"></span> @T("button.delete", "Eliminar")
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (PagedResult.TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <small class="text-muted">
                        @T("label.page", "Página") @PagedResult.PageNumber @T("label.of", "de") @PagedResult.TotalPages
                        — @PagedResult.TotalCount @T("label.total_records", "registros")
                    </small>

                    <nav aria-label="Pagination">
                        <ul class="pagination mb-0">
                            <li class="page-item @(PagedResult.HasPreviousPage ? "" : "disabled")">
                                <button class="page-link" @onclick="() => GoToPage(PagedResult.FirstPage)" disabled="@(!PagedResult.HasPreviousPage)">
                                    <span class="bi bi-chevron-double-left"></span>
                                </button>
                            </li>

                            <li class="page-item @(PagedResult.HasPreviousPage ? "" : "disabled")">
                                <button class="page-link" @onclick="() => GoToPage(PagedResult.PageNumber - 1)" disabled="@(!PagedResult.HasPreviousPage)">
                                    <span class="bi bi-chevron-left"></span>
                                </button>
                            </li>

                            @foreach (var pageNum in GetVisiblePages())
                            {
                                <li class="page-item @(pageNum == PagedResult.PageNumber ? "active" : "")">
                                    <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                                </li>
                            }

                            <li class="page-item @(PagedResult.HasNextPage ? "" : "disabled")">
                                <button class="page-link" @onclick="() => GoToPage(PagedResult.PageNumber + 1)" disabled="@(!PagedResult.HasNextPage)">
                                    <span class="bi bi-chevron-right"></span>
                                </button>
                            </li>

                            <li class="page-item @(PagedResult.HasNextPage ? "" : "disabled")">
                                <button class="page-link" @onclick="() => GoToPage(PagedResult.LastPage)" disabled="@(!PagedResult.HasNextPage)">
                                    <span class="bi bi-chevron-double-right"></span>
                                </button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public PagedResultModel<ContactModel>? PagedResult { get; set; }
    [Parameter] public IDictionary<string, string> Translations { get; set; } = new Dictionary<string, string>();
    [Parameter] public EventCallback<Guid> OnViewContact { get; set; }
    [Parameter] public EventCallback<Guid> OnEditContact { get; set; }
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }
    [Parameter] public EventCallback<string?> OnSearchChanged { get; set; }

    private Guid? _openMenuId;
    private string? _searchText;

    private void ToggleMenu(Guid id)
    {
        _openMenuId = _openMenuId == id ? null : id;
    }

    private async Task OnView(Guid id)
    {
        _openMenuId = null;
        await OnViewContact.InvokeAsync(id);
    }

    private async Task OnEdit(Guid id)
    {
        _openMenuId = null;
        await OnEditContact.InvokeAsync(id);
    }

    private async Task GoToPage(int page)
    {
        await OnPageChanged.InvokeAsync(page);
    }

    private async Task ExecuteSearch()
    {
        await OnSearchChanged.InvokeAsync(string.IsNullOrWhiteSpace(_searchText) ? null : _searchText.Trim());
    }

    private async Task ClearSearch()
    {
        _searchText = null;
        await OnSearchChanged.InvokeAsync(null);
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ExecuteSearch();
        }
    }

    private IEnumerable<int> GetVisiblePages()
    {
        if (PagedResult is null || PagedResult.TotalPages <= 0)
            yield break;

        const int maxVisible = 5;
        var totalPages = PagedResult.TotalPages;
        var current = PagedResult.PageNumber;

        var start = Math.Max(1, current - maxVisible / 2);
        var end = Math.Min(totalPages, start + maxVisible - 1);

        if (end - start + 1 < maxVisible)
            start = Math.Max(1, end - maxVisible + 1);

        for (var i = start; i <= end; i++)
            yield return i;
    }

    private string T(string key, string fallback)
    {
        return Translations.TryGetValue(key, out var value) ? value : fallback;
    }
}
