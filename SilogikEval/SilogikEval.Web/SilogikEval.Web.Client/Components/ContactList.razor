@using SilogikEval.Web.Client.Models

<div class="card shadow">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">@T("label.contacts", "Contactos")</h5>
    </div>
    <div class="card-body">
        @if (Contacts is null)
        {
            <div class="text-center py-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else if (!Contacts.Any())
        {
            <p class="text-muted text-center mb-0">@T("label.no_records", "No hay registros.")</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>@T("label.email", "Email")</th>
                            <th>@T("label.firstname", "Nombre")</th>
                            <th>@T("label.secondname", "Segundo nombre")</th>
                            <th>@T("label.lastname", "Apellido paterno")</th>
                            <th>@T("label.secondlastname", "Apellido materno")</th>
                            <th>@T("label.comments", "Comentarios")</th>
                            <th>@T("label.attachment", "Adjunto")</th>
                            <th class="text-center">@T("label.actions", "Acciones")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var contact in Contacts)
                        {
                            <tr>
                                <td>@contact.Email</td>
                                <td>@contact.FirstName</td>
                                <td>@(contact.SecondName ?? "—")</td>
                                <td>@contact.LastName</td>
                                <td>@(contact.SecondLastName ?? "—")</td>
                                <td>@contact.Comments</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(contact.FilePath))
                                    {
                                        <span class="badge bg-success">✓</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="position-relative d-inline-block">
                                        <button class="btn btn-sm btn-outline-secondary"
                                                @onclick="() => ToggleMenu(contact.Id)">
                                            <span class="bi bi-list"></span>
                                        </button>
                                        @if (_openMenuId == contact.Id)
                                        {
                                            <div class="dropdown-menu show shadow-sm" style="position:absolute; right:0; top:100%; z-index:1050; min-width:160px;">
                                                <button class="dropdown-item d-flex align-items-center gap-2" type="button"
                                                        @onclick="() => OnView(contact.Id)">
                                                    <span class="bi bi-eye"></span> @T("button.view", "Ver")
                                                </button>
                                                <button class="dropdown-item d-flex align-items-center gap-2" type="button"
                                                        @onclick="() => OnEdit(contact.Id)">
                                                    <span class="bi bi-pencil"></span> @T("button.edit", "Editar")
                                                </button>
                                                <div class="dropdown-divider"></div>
                                                <button class="dropdown-item d-flex align-items-center gap-2 text-danger" type="button" disabled>
                                                    <span class="bi bi-trash"></span> @T("button.delete", "Eliminar")
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public IEnumerable<ContactModel>? Contacts { get; set; }
    [Parameter] public IDictionary<string, string> Translations { get; set; } = new Dictionary<string, string>();
    [Parameter] public EventCallback<Guid> OnViewContact { get; set; }
    [Parameter] public EventCallback<Guid> OnEditContact { get; set; }

    private Guid? _openMenuId;

    private void ToggleMenu(Guid id)
    {
        _openMenuId = _openMenuId == id ? null : id;
    }

    private async Task OnView(Guid id)
    {
        _openMenuId = null;
        await OnViewContact.InvokeAsync(id);
    }

    private async Task OnEdit(Guid id)
    {
        _openMenuId = null;
        await OnEditContact.InvokeAsync(id);
    }

    private string T(string key, string fallback)
    {
        return Translations.TryGetValue(key, out var value) ? value : fallback;
    }
}
